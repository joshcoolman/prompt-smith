{
  "name": "prompt-smith",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3002",
    "dev:local": "docker compose up -d --wait && pnpm db:migrate:local && pnpm dev",
    "dev:local:stop": "docker compose down",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite preview --port $PORT --host 0.0.0.0",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:deploy": "node scripts/migrate.mjs",
    "db:migrate:local": "node --env-file=.env.local scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio",
    "setup:supabase": "node scripts/setup.mjs",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@effect/ai": "0.36.0",
    "@effect/ai-anthropic": "0.26.0",
    "@effect/platform": "0.96.2",
    "@supabase/supabase-js": "^2.110.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "^0.10.7",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/router-plugin": "^1.168.18",
    "drizzle-orm": "^0.45.2",
    "effect": "3.21.4",
    "lucide-react": "^0.545.0",
    "postgres": "^3.4.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@tanstack/devtools-vite": "^0.8.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/router-cli": "^1.167.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
