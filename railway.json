{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "startCommand": "pnpm start",
    "preDeployCommand": ["echo 'no pre-deploy step until Phase 1 adds migrations'"],
    "restartPolicyType": "ALWAYS",
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    }
  }
}
